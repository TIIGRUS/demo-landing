{
    "name": "travel-app",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "prepare": "husky install",
        "test": "vitest",
        "test-cypress": "cypress open",
        "test:a11y": "cypress run --spec cypress/e2e/accessibility.cy.ts",
        "generate-images": "node scripts/generate-responsive-images.js",
        "convert-small-images": "node scripts/convert-small-images.js",
        "optimize-all-images": "npm run generate-images && npm run convert-small-images",
        "lighthouse": "lhci autorun"
    },
    "lint-staged": {
        "*.css": [
            "stylelint --fix",
            "prettier --write"
        ],
        "*.html": [
            "prettier --write"
        ],
        "*.js": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@lhci/cli": "^0.15.1",
        "autoprefixer": "^10.4.24",
        "cssnano": "^7.1.2",
        "cypress": "^15.11.0",
        "cypress-axe": "^1.7.0",
        "cypress-real-events": "^1.15.0",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lint-staged": "^16.2.7",
        "postcss-preset-env": "^11.1.3",
        "prettier": "^3.8.1",
        "sharp": "^0.34.5",
        "stylelint": "^17.1.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^7.0.1",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vite-imagetools": "^9.0.3",
        "vite-plugin-image-optimizer": "^2.0.3",
        "vitest": "^4.0.18"
    }
}